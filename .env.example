# ============================================================
# 智能交通流量预测系统 - 环境变量配置
# 使用方法: 复制此文件为 .env 并修改相应配置
#   cp .env.example .env
# ============================================================

# ---------- Django 配置 ----------
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ---------- 数据库配置 ----------
# 选择数据库类型: sqlite / mysql
DB_ENGINE=sqlite

# MySQL 配置 (DB_ENGINE=mysql 时生效)
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_DATABASE=smart_traffic
MYSQL_USER=traffic_user
MYSQL_PASSWORD=traffic_pass_2024
MYSQL_ROOT_PASSWORD=root_pass_2024

# ---------- 数据路径 ----------
# nuScenes 数据集路径 (CenterPoint 3D感知模块)
NUSCENES_DATA_DIR=/app/centerpoint/nuscenes_data/nuScenes-mini-val

# YOLO 检测结果路径
YOLO_RESULTS_DIR=/app/data/yolo_results

# ---------- 模型存储 ----------
MODEL_STORAGE_DIR=/app/backend/media/models

# ---------- Redis (可选, 用于缓存) ----------
# REDIS_URL=redis://redis:6379/0
